import java.util.Scanner; // Importing Scanner class for user input

class TableOfGivenNumber {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in); // Creating Scanner object to take input  
         
        System.out.println("Enter a number:"); // Prompt user to enter a number   
        int number = input.nextInt(); // Reading the number input from user
        
        // Loop to generate multiplication table from 1 to 10
        for (int i = 1; i <= 10; i++) {
            System.out.println(number + " x " + i + " = " + (number * i)); // Printing multiplication result 
        }
        
        input.close(); // Closing Scanner object to prevent resource leak
    } 
}
